<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213E"
        android:padding="20dp"
        android:elevation="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🍽  RESTAURANT"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#E94560"
            android:letterSpacing="0.15"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Table Management"
            android:textSize="13sp"
            android:textColor="#8892A4"
            android:layout_marginTop="2dp"/>

        <!-- Legend Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical">

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/legend_dot_free"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Free"
                android:textColor="#A0AEC0"
                android:textSize="12sp"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="18dp"/>

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/legend_dot_occupied"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Occupied"
                android:textColor="#A0AEC0"
                android:textSize="12sp"
                android:layout_marginStart="6dp"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Table Grid -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <GridLayout
            android:id="@+id/tableGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:padding="16dp"
            android:useDefaultMargins="true"/>

    </ScrollView>

</LinearLayout>